# Reflex contract block. Insert into target SKILL.md frontmatter, above the
# closing `---`. Fill placeholders. Omit optional keys instead of writing null.
reflex:
  reflex_id: {reflex_id}
  source_skill_id: {source_skill_id}
  version: "{version}"
  contract_version: "1"

  input_schema:
    type: object
    properties:
      # field: { type: string }
    required: []
    additionalProperties: false

  output_schema:
    type: object
    properties:
      # field: { type: string }
    required: []
    additionalProperties: false

  timeout_seconds: 10
  determinism: pure            # pure | external_api | impure
  on_failure: fallback_to_agent  # fallback_to_agent | hard_fail | retry_once
  # side_effects: []

  examples:
    - input: {{}}
      output: {{}}
