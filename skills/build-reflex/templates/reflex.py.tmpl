#!/usr/bin/env python3
"""Reflex: {reflex_id}
Source skill:    {source_skill_id}
Reflex version:  {version}
Contract version: {contract_version}

Auto-generated by build-reflex. Implement run(). Keep the I/O contract.
"""
import json
import sys
from pathlib import Path

# Make sibling lib importable (validator lives in the build-reflex plugin).
_LIB = Path("/root/.claude/plugins/cache/build-reflex/build-reflex/0.1.0/lib")
if _LIB.exists() and str(_LIB) not in sys.path:
    sys.path.insert(0, str(_LIB))
try:
    from reflex_common import validate, ValidationError
except ImportError:  # graceful degrade — script still runs, just no output check
    def validate(*_a, **_k): pass
    class ValidationError(Exception): pass


# --- contract snapshot, kept in sync with SKILL.md `reflex:` block ---
CONTRACT = {{
    "reflex_id":       "{reflex_id}",
    "source_skill_id": "{source_skill_id}",
    "version":         "{version}",
    "input_schema":    {input_schema_json},
    "output_schema":   {output_schema_json},
    "examples":        {examples_json},
}}


def run(args: dict) -> dict:
    """Implement me. Read from `args` (matches input_schema), return dict matching output_schema."""
    raise NotImplementedError("reflex {reflex_id}: run() not implemented yet")


def _main():
    args = json.loads(sys.stdin.read() or "{{}}")
    out = run(args)
    validate(out, CONTRACT["output_schema"])
    json.dump(out, sys.stdout)


def _selfcheck():
    failures = 0
    for i, ex in enumerate(CONTRACT["examples"]):
        try:
            got = run(ex["input"])
            validate(got, CONTRACT["output_schema"])
            if got != ex["output"]:
                print(f"FAIL example {{i}}: got {{got!r}} want {{ex['output']!r}}", file=sys.stderr)
                failures += 1
        except Exception as e:
            print(f"FAIL example {{i}}: {{type(e).__name__}}: {{e}}", file=sys.stderr)
            failures += 1
    if failures == 0:
        print("ok")
        sys.exit(0)
    sys.exit(1)


if __name__ == "__main__":
    if "--selfcheck" in sys.argv:
        _selfcheck()
    elif "--bench" in sys.argv:
        import time as _t
        N = 1000
        ex = CONTRACT["examples"][0]["input"]
        # warm
        for _ in range(10): run(ex)
        samples = []
        for _ in range(N):
            t0 = _t.perf_counter()
            run(ex)
            samples.append((_t.perf_counter() - t0) * 1000)
        samples.sort()
        print(f"n={{N}}  p50={{samples[N//2]:.3f}}ms  p99={{samples[int(N*0.99)]:.3f}}ms  max={{samples[-1]:.3f}}ms")
    else:
        try:
            _main()
        except Exception as e:
            print(f"reflex error: {{type(e).__name__}}: {{e}}", file=sys.stderr)
            sys.exit(1)
